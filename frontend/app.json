{
  "expo": {
    "name": "BhoomiMitra",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.ragisoilguide.zk4vp0",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of your soil health card",
        "NSPhotoLibraryUsageDescription": "Select soil card photos from your gallery",
        "NSLocationWhenInUseUsageDescription": "Tag your farm plot with GPS location"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2E5B3D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.ragisoilguide.zk4vp0",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2E5B3D"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
